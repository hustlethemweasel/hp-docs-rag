# --- LLM provider (contract: the configuration table in SPEC.md) ---
LLM_PROVIDER=ollama            # anthropic | openai | ollama
LLM_MODEL=qwen3.5:4b
ANTHROPIC_API_KEY=             # only for LLM_PROVIDER=anthropic
OPENAI_API_KEY=                # only for LLM_PROVIDER=openai
OLLAMA_URL=http://ollama:11434

# --- RAG (fixed embedding model; changing it requires re-ingestion) ---
EMBEDDING_MODEL=microsoft/harrier-oss-v1-270m
CHUNK_TOKENS=450
CHUNK_OVERLAP=80
RETRIEVAL_CANDIDATES=20
TOP_K=6
REFUSAL_THRESHOLD=0.0          # tuned in Milestone 5

# --- Infrastructure ---
DOCS_DIR=/docs
LOG_LEVEL=info
FRONTEND_ORIGIN=http://localhost:3000   # CORS-allowed origin for the browser SPA
HF_TOKEN=                      # optional; avoids Hugging Face rate limits on first model download
# DATABASE_URL is set by docker-compose; for local dev:
# DATABASE_URL=postgresql+asyncpg://app:app@localhost:5432/hpdocs
